{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "declaration": true,
    "declarationDir": "dist/types",
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
  },
  "include": ["src"],
  "exclude": ["src/__tests__", "src/**/*.test.ts", "src/**/*.test.tsx", "src/test-setup.ts"]
}