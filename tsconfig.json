{
  "compilerOptions": {
    "target": "ES2020",
    "strict": true,
    "noEmit": false,
    "outDir": "dist",
    "skipLibCheck": true,
    "declaration": true,
    "declarationDir": "dist/types",
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler"
  },
  "include": ["src"],
  "exclude": [
    "src/test-setup.ts",
    "src/__tests__",
  ]
}